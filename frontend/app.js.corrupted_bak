// â”€â”€ Delete Part â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
async function deletePart(partId) {
    if (!confirm('Remove this part from the vault?')) return;
    try {
        const resp = await fetch(API + '/api/vault/parts/' + encodeURIComponent(partId), { method: 'DELETE' });
        if (!resp.ok) throw new Error('Delete failed');
        showToast('Part removed from vault', 'success');
        // Refresh vault if on vault tab
        if (document.getElementById('panel-vault').classList.contains('active')) {
            loadVaultData();
        }
    } catch (err) {
        showToast('Delete error: ' + err.message, 'error');
    }
}


