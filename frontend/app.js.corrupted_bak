// â”€â”€ Analyze Button â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
btnAnalyze.addEventListener('click', runAnalysis);

async function runAnalysis() {
    if (selectedFiles.length === 0) return;

    const btnText = btnAnalyze.querySelector('.btn-text');
    const btnLoader = btnAnalyze.querySelector('.btn-loader');
    btnText.hidden = true;
    btnLoader.hidden = false;
    btnAnalyze.disabled = true;

    // Show pipeline
    pipelineCard.hidden = false;
    const steps = ['upload', 'yolo', 'condition', 'grounding', 'vault'];
    steps.forEach(s => {
        $(`step-${s}`).className = 'pipeline-step';
        $(`step-${s}`).querySelector('.step-status').textContent = 'Waiting';
    });

    // Animate steps
    setStepActive('upload');

    try {
        // Build form data
        const formData = new FormData();
        selectedFiles.forEach(f => formData.append('images', f));
        formData.append('device_model', $('device-model').value || 'Unknown Device');
        formData.append('failure_cause', $('failure-cause').value || 'Not specified');
        formData.append('skill_level', $('skill-level').value);

        const activeTools = Array.from(document.querySelectorAll('.chip.active')).map(c => c.dataset.tool);
        formData.append('available_tools', JSON.stringify(activeTools.length ? activeTools : ['multimeter']));

        setStepDone('upload');
        setStepActive('yolo');

        // Send to API
        const resp = await fetch(`${API}/api/teardown`, { method: 'POST', body: formData });
        if (!resp.ok) {
            let errorMsg = `API error: ${resp.status}`;
            try {
                const errorData = await resp.json();
                if (errorData.detail) {
                    errorMsg = errorData.detail;
                }
            } catch (e) {}
            throw new Error(errorMsg);
        }

        setStepDone('yolo');
        setStepActive('condition');
        await sleep(300);
        setStepDone('condition');
        setStepActive('grounding');
        await sleep(300);
        setStepDone('grounding');
        setStepActive('vault');
        await sleep(200);
        setStepDone('vault');

        lastManifest = await resp.json();
        renderResults(lastManifest);
        showToast('Analysis complete!', 'success');

        // Switch to results tab
        navTabs.forEach(t => t.classList.remove('active'));
        panels.forEach(p => p.classList.remove('active'));
        $('nav-results').classList.add('active');
        $('panel-results').classList.add('active');

    } catch (err) {
        console.error(err);
        showToast(`Error: ${err.message}`, 'error');
        pipelineCard.hidden = true;
    } finally {
        btnText.hidden = false;
        btnLoader.hidden = true;
        btnAnalyze.disabled = false;
    }
}

function setStepActive(name) {
    const el = $(`step-${name}`);
    el.className = 'pipeline-step active';
    el.querySelector('.step-status').textContent = 'Running...';
}

function setStepDone(name) {
    const el = $(`step-${name}`);
    el.className = 'pipeline-step done';
    el.querySelector('.step-status').textContent = 'Done';
    // Also mark connector
    const connectors = el.parentElement.querySelectorAll('.step-connector');
    // Find the connector after this step
    let found = false;
    el.parentElement.childNodes.forEach(node => {
        if (node === el) found = true;
        else if (found && node.classList && node.classList.contains('step-connector')) {
            node.classList.add('done');
            found = false;
        }
    });
}

// â”€â”€ Render Results â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
function renderResults(manifest) {
    // Setup summary element if not exists
    let summaryEl = document.getElementById('results-summary');
    if (!summaryEl) {
        const parent = document.getElementById('parts-grid');
        if (parent) {
            summaryEl = document.createElement('div');
            summaryEl.id = 'results-summary';
            parent.before(summaryEl);
        }
    }
    const partsGrid = $('parts-grid');
    const resultsEmpty = $('results-empty');
    const resultsSummary = $('results-summary');
    const damagesSection = $('damages-section');
    const damagesGrid = $('damages-grid');

    if (btnExportReport) btnExportReport.hidden = true;

    // Summary badges
    const fCount = manifest.parts.filter(p => p.status === 'functional').length;
    const rCount = manifest.parts.filter(p => p.status === 'repairable').length;
    const uCount = manifest.parts.filter(p => p.status === 'unsafe').length;

    resultsSummary.innerHTML = `
        <span class="summary-badge functional">â— ${fCount} Functional</span>
        <span class="summary-badge repairable">â— ${rCount} Repairable</span>
        <span class="summary-badge unsafe">â— ${uCount} Unsafe</span>
    `;

    if (manifest.parts.length === 0) {
        resultsEmpty.style.display = '';
        partsGrid.innerHTML = '';
        return;
    }

    if (btnExportReport && manifest.teardown_id) {
        btnExportReport.hidden = false;
        btnExportReport.onclick = () => exportReport(manifest.teardown_id);
    }

    resultsEmpty.style.display = 'none';
    partsGrid.innerHTML = manifest.parts.map((part, i) => renderPartCard(part, i)).join('');

    // Damages
    if (manifest.board_damages && manifest.board_damages.length > 0) {
        damagesSection.hidden = false;
        damagesGrid.innerHTML = manifest.board_damages.map(d => `
            <div class="damage-card">
                <div class="damage-type">${d.defect_type}</div>
                <div class="damage-conf">${(d.confidence * 100).toFixed(0)}% confidence</div>
                ${d.affects_part ? `<div class="damage-affects">Affects: ${d.affects_part}</div>` : ''}
            </div>
        `).join('');
    } else {
        damagesSection.hidden = true;
    }
}

function renderPartCard(part, delay) {
    const confPct = (part.confidence * 100).toFixed(0);
    const confClass = part.confidence > 0.8 ? 'high' : part.confidence > 0.5 ? 'medium' : 'low';

    let specsHTML = '';
    if (part.specs) {
        const s = part.specs;
        const entries = [];
        if (s.voltage) entries.push(['Voltage', s.voltage]);
        if (s.current_rating) entries.push(['Current', s.current_rating]);
        if (s.package) entries.push(['Package', s.package]);
        if (s.part_number) entries.push(['Part #', s.part_number]);
        if (s.source) entries.push(['Source', s.source]);
        if (s.raw) {
            Object.entries(s.raw).forEach(([k, v]) => {
                if (!['note', 'ocr_text'].includes(k) && entries.length < 6) {
                    entries.push([k.replace(/_/g, ' '), String(v)]);
                }
            });
        }
        if (entries.length > 0) {
            specsHTML = `<div class="part-specs">${entries.map(([k, v]) => `
                <div class="spec-item">
                    <span class="spec-label">${k}</span>
                    <span class="spec-value">${v}</span>
                </div>
            `).join('')}</div>`;
        }
    }

    let descHTML = '';
    if (part.description) {
        descHTML = `<div class="part-description">${escapeHTML(part.description)}</div>`;
    }
    let reuseHTML = '';
    if (part.reuse_suggestion) {
        reuseHTML = `<div class="part-reuse">â™» ${escapeHTML(part.reuse_suggestion)}</div>`;
    }
    let noteHTML = '';
    if (part.repair_note) {
        noteHTML = `<div class="part-note repair">${escapeHTML(part.repair_note)}</div>`;
    }
    if (part.disposal_reason) {
        noteHTML = `<div class="part-note disposal">${escapeHTML(part.disposal_reason)}</div>`;
    }

    const detection = part.detection;
    let sourceHTML = '';
    if (detection) {
        sourceHTML = `<div class="part-source">ðŸŽ¯ YOLO: ${escapeHTML(detection.yolo_class)} (${(detection.yolo_confidence * 100).toFixed(0)}%)</div>`;
    }

    return `
        <div class="part-card" style="animation-delay: ${delay * 80}ms">
            <div class="part-card-header">
                <div>
                    <div class="part-name">${escapeHTML(part.name)}</div>
                    <div class="part-category">${escapeHTML(part.category || '')}</div>
                </div>
                <span class="status-badge ${part.status}">${part.status}</span>
            </div>
            <div class="part-confidence">
                <div class="confidence-bar">
                    <div class="confidence-fill ${confClass}" style="width: ${confPct}%"></div>
                </div>
                <span class="confidence-text">${confPct}%</span>
            </div>
            ${specsHTML}
            ${descHTML}
            ${reuseHTML}
            
            ${noteHTML}
            ${sourceHTML}
        </div>
    `;
}

// â”€â”€ Vault â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
async function updateImpactCounter(stats) {
    if (!stats) return;
    const partsEl = document.getElementById('impact-parts');
    const sessionsEl = document.getElementById('impact-sessions');
    if (partsEl) partsEl.textContent = stats.total_parts || 0;
    if (sessionsEl) sessionsEl.textContent = stats.teardown_sessions || 0;
}

async function loadVaultData() {
    try {
        const [statsResp, partsResp] = await Promise.all([
            fetch(`${API}/api/vault/stats`),
            fetch(`${API}/api/vault/parts`),
        ]);
        if (statsResp.ok) {
            const stats = await statsResp.json();
            updateImpactCounter(stats);
            // removed duplicate
            $('stat-total').textContent = stats.total_parts || 0;
            $('stat-functional').textContent = stats.functional || 0;
            $('stat-repairable').textContent = stats.repairable || 0;
            $('stat-unsafe').textContent = stats.unsafe || 0;
        }
        if (partsResp.ok) {
            const data = await partsResp.json();
            renderVaultParts(data.parts || [], $('vault-parts-grid'));
        }
    } catch (err) {
        console.error('Vault load error:', err);
    }
}

const searchInput = $('vault-search');
const btnSearch = $('btn-vault-search');

btnSearch.addEventListener('click', vaultSearch);
searchInput.addEventListener('keydown', e => { if (e.key === 'Enter') vaultSearch(); });

async function vaultSearch() {
    const q = searchInput.value.trim();
    if (!q) return;

    try {
        const resp = await fetch(`${API}/api/vault/search?q=${encodeURIComponent(q)}&top_k=12`);
        if (!resp.ok) throw new Error('Search failed');
        const data = await resp.json();
        const vaultResults = $('vault-results');

        if (data.results.length === 0) {
            vaultResults.innerHTML = `<div class="results-empty"><p>No parts match "${q}"</p></div>`;
            return;
        }

        vaultResults.innerHTML = `
            <h3 class="section-subtitle">${data.count} results for "${q}"</h3>
            <div class="vault-parts-grid">
                ${data.results.map(r => renderVaultResultCard(r)).join('')}
            </div>
        `;
    } catch (err) {
        showToast(`Search error: ${err.message}`, 'error');
    }
}

function renderVaultResultCard(result) {
    const p = result;
    return `
        <div class="part-card">
            <div class="part-card-header">
                <div>
                    <div class="part-name">${escapeHTML(p.name)} <span class="similarity-badge">${(p.similarity * 100).toFixed(0)}% match</span></div>
                    <div class="part-category">${escapeHTML(p.category || '')}</div>
                </div>
                <span class="status-badge ${p.status}">${p.status}</span>
            </div>
            ${p.specs ? renderSpecsInline(p.specs) : ''}
            ${p.repair_note ? `<div class="part-note repair">${escapeHTML(p.repair_note)}</div>` : ''}
            <div class="part-source">ðŸ“¦ Vault: ${escapeHTML(p.part_id)}</div>
        </div>
    `;
}

function renderSpecsInline(specs) {
    if (!specs || typeof specs !== 'object') return '';
    const entries = Object.entries(specs).filter(([k, v]) => v && k !== 'note').slice(0, 4);
    if (entries.length === 0) return '';
    return `<div class="part-specs">${entries.map(([k, v]) => `
        <div class="spec-item">
            <span class="spec-label">${escapeHTML(k.replace(/_/g, ' '))}</span>
            <span class="spec-value">${escapeHTML(v)}</span>
        </div>
    `).join('')}</div>`;
}

function renderVaultParts(parts, container) {
    if (parts.length === 0) {
        container.innerHTML = '<div class="results-empty"><p>Vault is empty. Run a teardown to add parts.</p></div>';
        return;
    }
    container.innerHTML = parts.map(p => `
        <div class="part-card">
            <div class="part-card-header">
                <div>
                    <div class="part-name">${escapeHTML(p.name)}</div>
                    <div class="part-category">${escapeHTML(p.category || '')}</div>
                </div>
                <span class="status-badge ${p.status}">${p.status}</span>
            </div>
            ${p.specs ? renderSpecsInline(p.specs) : ''}
            <div class="part-source">
                ${p.is_available ? 'âœ… Available' : `ðŸ”’ Used in ${escapeHTML(p.used_in_build || 'build')}`}
                Â· Session: ${escapeHTML(p.session_id)}
            </div>
        </div>
    `).join('');
}

// â”€â”€ Export Report â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
async function exportReport(teardown_id) {
    try {
        const resp = await fetch(`${API}/api/report/${teardown_id}`);
        if (!resp.ok) throw new Error('Report generation failed');
        const report = await resp.json();
        
        const device = report.context?.device_model || 'Unknown Device';
        const partsHtml = (report.parts || []).map(p => {
            const badgeCls = p.status === 'functional' ? '#d4edda' : p.status === 'repairable' ? '#fff3cd' : '#f8d7da';
            const badgeText = p.status === 'functional' ? '#155724' : p.status === 'repairable' ? '#856404' : '#721c24';
            return '<div style="border:1px solid #ddd;border-radius:8px;padding:16px;margin:8px 0">' +
                '<h3 style="margin:0">' + escapeHTML(p.name||'') + '</h3>' +
                '<p style="margin:4px 0;color:#666">' + (p.category||'') + ' <span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:12px;font-weight:600;background:' + badgeCls + ';color:' + badgeText + '">' + (p.status||'') + '</span></p>' +
                '<p><strong>Confidence:</strong> ' + (p.confidence*100).toFixed(0) + '%</p>' +
                (p.description ? '<p>' + escapeHTML(p.description) + '</p>' : '') +
                (p.reuse_suggestion ? '<p>â™» ' + escapeHTML(p.reuse_suggestion) + '</p>' : '') +
                (p.specs ? '<p><strong>Specs:</strong> ' + Object.entries(p.specs).filter(([k]) => k !== 'raw').map(([k,v]) => k + ': ' + v).join(', ') + '</p>' : '') +
                (p.repair_note ? '<p><strong>Repair:</strong> ' + escapeHTML(p.repair_note) + '</p>' : '') +
                '</div>';
        }).join('');
        const html = '<!DOCTYPE html><html><head><meta charset="utf-8"><title>Repair Guide - ' + device + '</title>' +
            '<style>body{font-family:system-ui,sans-serif;max-width:800px;margin:auto;padding:20px;background:#f5f5f5}' +
            '.header{background:#fff;border-radius:12px;padding:24px;margin-bottom:20px}' +
            'h1{margin:0 0 8px 0}.footer{text-align:center;color:#999;font-size:12px;margin-top:40px}' +
            '</style></head><body>' +
            '<div class="header"><h1>Frankenstein Repair Guide</h1>' +
            '<p style="color:#666">Device: ' + device + '</p>' +
            '<p style="color:#666">Teardown ID: ' + teardown_id + '</p>' +
            '<p style="color:#666">Generated: ' + new Date().toLocaleDateString() + '</p></div>' +
            partsHtml +
            '<div class="footer">Generated by Frankenstein - E-Waste Component Recovery System</div></body></html>';
        const dataStr = "data:text/html;charset=utf-8," + encodeURIComponent(html);
        const a = document.createElement('a');
        a.setAttribute("href", dataStr);
        a.setAttribute("download", 'repair-guide-' + teardown_id + '.html');
        document.body.appendChild(a);
        a.click();
        a.remove();
        showToast('Repair Guide downloaded (HTML)', 'success');
    } catch (err) {
        showToast('Export error: ' + err.message, 'error');
    }
}

// â”€â”€ Toast â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
function showToast(msg, type = 'info') {
    const container = $('toast-container');
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.textContent = msg;
    container.appendChild(toast);
    setTimeout(() => toast.remove(), 3000);
}

// â”€â”€ Health Check â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
async function checkAPI() {
    try {
        const resp = await fetch(`${API}/api/health`);
        if (resp.ok) {
            $('api-status').className = 'status-dot online';
            $('api-status-text').textContent = 'Online';
        } else {
            throw new Error();
        }
    } catch {
        $('api-status').className = 'status-dot offline';
        $('api-status-text').textContent = 'Offline';
    }
}

